@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@model List<RestaaurantManagement.DtoLayer.Dtos.DailyReport.ResultDailyReportDto>

@{
    ViewData["Title"] = "Günlük Rapor Arşivi";
    Layout = "~/Views/UIControler/Index.cshtml";
    var activeShift = HttpContextAccessor.HttpContext.Session.GetString("ActiveShift") ?? "Gunduz";
}

<style>
    .ls-1 { letter-spacing: 1px; font-size: 0.7rem; }
    
    /* Mobil Dokunuşlar */
    @@media (max-width: 768px) {
        .display-6 { font-size: 1.8rem; } /* Rakamları mobilde küçült */
        .container { padding-left: 10px; padding-right: 10px; }
        .card-body { padding: 1.25rem !important; }
        .btn-lg { width: 100%; font-size: 1rem; padding: 12px !important; }
    }

    .card { transition: all 0.3s ease; border: 1px solid rgba(0,0,0,0.05) !important; overflow: hidden; }
    .card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }

    .hover-opacity-100:hover { opacity: 1 !important; }
    .bg-dark-card { background-color: #1a1d21 !important; color: white !important; }
</style>

<div class="container-fluid px-3 mt-3">
    @* Başlık ve Sayaç *@
    <div class="row align-items-center mb-3">
        <div class="col-8">
            <h4 class="fw-bold mb-0">
                <i class="bi bi-archive text-primary me-2"></i>Rapor Arşivi
            </h4>
        </div>
        <div class="col-4 text-end">
            <span class="badge bg-success rounded-pill px-2 py-2 shadow-sm text-white">
                <strong>@Model.Count</strong> Kayıt
            </span>
        </div>
    </div>

    @* Filtreleme Alanı *@
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3 p-md-4">
            <form method="get" asp-action="Index" class="row g-2 g-md-3 align-items-end">
                <div class="col-6 col-md-4">
                    <label class="form-label small fw-bold text-muted text-uppercase mb-1">Başlangıç</label>
                    <input type="date" name="start" value="@ViewBag.StartDate" class="form-control form-control-sm rounded-3 border-0 bg-light" />
                </div>
                <div class="col-6 col-md-4">
                    <label class="form-label small fw-bold text-muted text-uppercase mb-1">Bitiş</label>
                    <input type="date" name="end" value="@ViewBag.EndDate" class="form-control form-control-sm rounded-3 border-0 bg-light" />
                </div>
                <div class="col-12 col-md-4">
                    <button type="submit" class="btn btn-success btn-sm w-100 rounded-3 fw-bold py-2">
                        <i class="bi bi-filter me-1"></i> Filtrele
                    </button>
                </div>
            </form>
        </div>
    </div>

    @* Analiz Butonu *@
    <div class="mb-4">
        <a id="btnPeriodicalAnalysis" href="#" class="btn btn-outline-danger btn-lg rounded-pill shadow-sm fw-bold">
            <i class="bi bi-graph-up-arrow me-2"></i>Final Rapor Analizi
        </a>
    </div>

    @* Rapor Kartları *@
    <div class="row g-3">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                var isDay = item.ShiftType == "Gunduz";

                <div class="col-12 col-sm-6 col-xl-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 @(isDay ? "bg-white" : "bg-dark-card")">

                        @* Kar/Zarar Çizgisi *@
                        <div class="position-absolute top-0 start-0 w-100" style="height: 5px; background: @(item.NetProfit >= 0 ? "linear-gradient(90deg, #00b09b, #96c93d)" : "linear-gradient(90deg, #ff416c, #ff4b2b)")"></div>

                        <div class="card-body">
                            @* Kart Başlık *@
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center @(isDay ? "bg-warning text-dark" : "bg-primary text-white")" style="width: 40px; height: 40px;">
                                        <i class="bi @(isDay ? "bi-sun-fill" : "bi-moon-stars-fill") fs-5"></i>
                                    </div>
                                    <div class="ms-3">
                                        <h6 class="mb-0 fw-bold">@item.Date.ToString("dd MMM yyyy")</h6>
                                        <small class="text-uppercase ls-1 opacity-75">@item.ShiftType</small>
                                    </div>
                                </div>
                                <a href="/Report/DeleteDailyReport/@item.Id" class="text-danger opacity-50 hover-opacity-100" onclick="return confirm('Bu raporu silmek istediğinize emin misiniz?')">
                                    <i class="bi bi-trash3-fill fs-5"></i>
                                </a>
                            </div>

                            @* Net Kar Rakamı *@
                            <div class="text-center py-2">
                                <small class="text-uppercase fw-semibold opacity-50 mb-1 d-block" style="font-size: 0.65rem;">Net Kar / Zarar</small>
                                <h3 class="fw-bold @(item.NetProfit >= 0 ? "text-success" : "text-danger")">
                                    @item.NetProfit.ToString("C2")
                                </h3>
                            </div>

                            @* Özet Bilgiler *@
                            <div class="rounded-3 p-2 my-3 @(isDay ? "bg-light text-dark" : "bg-white bg-opacity-10 text-white")">
                                <div class="d-flex justify-content-between mb-1 px-2">
                                    <span class="small opacity-75">Gelir:</span>
                                    <span class="small fw-bold text-success">+@item.TotalIncome.ToString("N2") ₺</span>
                                </div>
                                <div class="d-flex justify-content-between px-2">
                                    <span class="small opacity-75">Gider:</span>
                                    <span class="small fw-bold text-danger">-@item.TotalOutcome.ToString("N2") ₺</span>
                                </div>
                            </div>

                            @* Buton *@
                            <a href="@Url.Action("SelectFixedExpenses", "Report", new { 
                                startDate = item.Date.ToString("yyyy-MM-dd"), 
                                endDate = item.Date.ToString("yyyy-MM-dd"), 
                                ShiftType = item.ShiftType 
                            })" class="btn @(isDay ? "btn-outline-dark" : "btn-primary") w-100 rounded-pill py-2 fw-bold btn-sm">
                                <i class="bi bi-eye me-1"></i> Detayları Gör
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 bg-white rounded-4 shadow-sm border">
                <i class="bi bi-search display-4 text-muted opacity-25"></i>
                <p class="mt-3 text-muted fw-bold">Rapor kaydı bulunamadı.</p>
                <a href="/Home/Index" class="btn btn-primary rounded-pill px-4">Kasa Sayfasına Git</a>
            </div>
        }
    </div>
</div>

<script>
    document.getElementById('btnPeriodicalAnalysis').addEventListener('click', function(e) {
        e.preventDefault();
        let start = document.getElementsByName('start')[0].value;
        let end = document.getElementsByName('end')[0].value;
        if(start && end) {
            window.location.href = `/Report/PeriodicalAnalysis?start=${start}&end=${end}`;
        } else {
            alert("Analiz için lütfen tarih aralığı seçin!");
        }
    });
</script>