@model RestaaurantManagement.DtoLayer.Dtos.UserDto.LoginDTO

@{
    Layout = null; // Giriş sayfasında ana Layout'u kullanmıyoruz
}

<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap | Restoran Yönetim Paneli</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    
    <style>
            body {
                background-color: #f8f9fa;
                height: 100vh;
            }

            .login-container {
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .login-card {
                border: none;
                border-radius: 15px;
                overflow: hidden;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
                max-width: 900px;
                width: 100%;
            }

            .login-img {
                background: url('https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80');
                background-size: cover;
                background-position: center;
                min-height: 400px;
            }

            .form-control {
                border-radius: 8px;
                padding: 12px;
                border: 1px solid #dee2e6;
            }

            .form-control:focus {
                box-shadow: 0 0 0 0.25 border-color: #0d6efd;
            }

            .btn-login {
                padding: 12px;
                border-radius: 8px;
                font-weight: 600;
                background: linear-gradient(45deg, #212529, #495057);
                border: none;
                transition: all 0.3s;
            }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
            }
    </style>
</head>

<body>

    <div class="container login-container">

        <div class="card login-card">
            <div class="row g-0">
                <div class="col-md-6 d-none d-md-block login-img">
                    <div class="h-100 d-flex flex-column justify-content-end p-5 text-white bg-dark bg-opacity-25">
                        <h2 class="fw-bold">Lezzet Yönetimi</h2>
                        <p>Restoranınızın gelir, gider ve raporlarını tek bir panelden kolayca yönetin.</p>
                    </div>
                </div>
            
                <div class="col-md-6 p-4 p-lg-5 bg-white">
                    <div class="text-center mb-4">
                        <i class="bi bi-person-circle fs-1 text-primary"></i>
                        <h3 class="mt-2 fw-bold text-dark">Hoş Geldiniz</h3>
                        <p class="text-muted">Lütfen panel erişimi için giriş yapın</p>
                    </div>

                    <form asp-action="Index" asp-controller="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Kullanıcı Adı</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-person"></i></span>
                                <input type="text" asp-for="UserName" class="form-control border-start-0 bg-light"
                                       placeholder="Kullanıcı adınızı girin" required>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold">Parola</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock"></i></span>
                                    <input type="password" asp-for="Password" class="form-control border-start-0 bg-light"
                                           placeholder="••••••••" required>
                                    </div>
                                </div>

                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary btn-login text-white">
                                        Giriş Yap <i class="bi bi-arrow-right-short ms-1"></i>
                                    </button>
                                </div>
                            </form>

                            <div class="mt-4 text-center">
                                <p class="small text-muted">Hesabınız yok mu? <a href="/Register/Index"
                                                                                     class="text-decoration-none fw-bold">Kayıt Ol</a></p>
                                </div>
                
                                <div class="mt-5 text-center">
                                    <p class="text-muted" style="font-size: 0.8rem;">&copy; 2026 @DateTime.Now.Year Yunus Küçük Dev.
                                        Tüm Hakları Saklıdır.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
                </body>

            </html>